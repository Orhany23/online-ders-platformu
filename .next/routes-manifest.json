{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/admin/users/[id]",
      "regex": "^/api/admin/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/users/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/courses/[id]",
      "regex": "^/api/courses/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/courses/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/lessons/[id]",
      "regex": "^/api/lessons/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/lessons/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/livesessions/[id]",
      "regex": "^/api/livesessions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/livesessions/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/progress/[courseId]",
      "regex": "^/api/progress/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcourseId": "nxtPcourseId"
      },
      "namedRegex": "^/api/progress/(?<nxtPcourseId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/courses/[id]",
      "regex": "^/courses/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/courses/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/instructor/courses/[id]/edit",
      "regex": "^/instructor/courses/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/instructor/courses/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
    {
      "page": "/learn/[courseId]/[lessonId]",
      "regex": "^/learn/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcourseId": "nxtPcourseId",
        "nxtPlessonId": "nxtPlessonId"
      },
      "namedRegex": "^/learn/(?<nxtPcourseId>[^/]+?)/(?<nxtPlessonId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
